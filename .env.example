# MySQL（本地示例：先建库 CREATE DATABASE anycli CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;）
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/anycli"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

# GitHub OAuth 的 redirect_uri 由此项决定。必须与下面_callback 在 GitHub 后台登记的完全一致。
# 本地示例：用 http://localhost:3000 打开本站，就不要在 GitHub 里填 127.0.0.1 或 https。
# AUTH_URL="http://localhost:3000"

# GitHub：Settings → Developer settings → OAuth Apps
# 「Authorization callback URL」唯一填这一行（不要多加尾部斜杠）：
#   {AUTH_URL}/api/auth/callback/github
# 例如：http://localhost:3000/api/auth/callback/github
#
# Client ID / Secret（也可用 GITHUB_ID、GITHUB_SECRET）
# AUTH_GITHUB_ID="Ov23li..."
# AUTH_GITHUB_SECRET="..."

# GitHub API（同步仓库 Star，可选；不设则匿名约 60 次/小时）
# GITHUB_TOKEN="ghp_xxxx"

# 逗分号分隔：邮箱注册/GitHub 同邮箱时自动 isAdmin
ADMIN_EMAILS="you@example.com"

# 可选：默认管理员（邮箱 + 密码）。服务启动时自动 upsert；仅当两项都配置时才生效。
# 已存在同邮箱用户时：默认只保证 isAdmin=true，不覆盖密码；需改密码时设 BOOTSTRAP_ADMIN_SYNC_PASSWORD=1
# BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
# BOOTSTRAP_ADMIN_PASSWORD="change-me-8-chars-min"
# BOOTSTRAP_ADMIN_HANDLE="admin"
# BOOTSTRAP_ADMIN_NAME="管理员"
# BOOTSTRAP_ADMIN_SYNC_PASSWORD="0"
